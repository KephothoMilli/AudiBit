{
  "manifest_version": 3,
  "name": "Audibit - AI QA Assistant",
  "version": "1.0.0",
  "description": "Proactive QA assistant analyzing web pages for UI/UX and security improvements.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5001/*",
    "http://127.0.0.1:9099/*",
    "http://127.0.0.1:8080/*",
    "https://w3bn3xt.web.app/*",
    "https://*.cloudfunctions.net/*",
    "https://*.run.app/*"
  ],
  "icons": {
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/content-script.ts"
      ],
      "run_at": "document_end"
    }
  ],
  "devtools_page": "src/devtools/panel.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
