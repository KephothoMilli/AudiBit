# Circle API Configuration
# Get your API key from Circle Console: https://developers.circle.com/console
CIRCLE_API_KEY=your_api_key_here

# Optional: Current entity secret for validation (masked version)
# CIRCLE_ENTITY_SECRET=****your_secret_here

# Optional: Custom directories (defaults to ~/.circle/)
# CIRCLE_RECOVERY_DIR=/path/to/recovery/directory
# CIRCLE_ENTITY_SECRET_DIR=/path/to/secret/directory

# Optional: Use test mode (skips actual API calls)
# CIRCLE_TEST_MODE=true